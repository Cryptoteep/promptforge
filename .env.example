# Database URL — SQLite local file.
# The db/ directory is gitignored. Adjust the path as needed.
DATABASE_URL="file:./db/custom.db"

# The z-ai-web-dev-sdk reads its API key from the environment.
# Set this to your z-ai API key (see https://z.ai for details).
# NEVER commit your real .env file — it is gitignored by default.
# ZAI_API_KEY="your-z-ai-api-key-here"
